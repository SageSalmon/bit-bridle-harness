# Copy to .env and fill in. bit-bridle reads these on startup.

# Required: your GLM API key.
GLM_API_KEY=

# OpenAI-compatible base URL for the GLM endpoint. Pick one:
#   Zhipu (mainland):    https://open.bigmodel.cn/api/paas/v4
#   z.ai (international): https://api.z.ai/api/paas/v4
#   self-hosted vLLM:    http://localhost:8000/v1
GLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4

# Model id served by that endpoint.
GLM_MODEL=glm-5.2

# Optional tuning.
GLM_TEMPERATURE=0.3
GLM_MAX_TOOL_ITERATIONS=25
